# Copy to .deepseek.env (or any name) and load via systemd EnvironmentFile.
# Do NOT commit the populated file.

# DeepSeek API key (https://platform.deepseek.com)
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Shared secret for /api/* — generate with: python3 -c "import secrets;print(secrets.token_urlsafe(24))"
INTERVIEW_TOKEN=replace-with-random-secret
